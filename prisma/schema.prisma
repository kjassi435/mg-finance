generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  phone     String?
  role      String   @default("USER") // USER or ADMIN
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  applications LoanApplication[]
}

model LoanApplication {
  id                String   @id @default(cuid())
  applicationId     String   @unique // Unique application reference like MG-2024-001
  userId            String
  loanType          String   // MUDRA, BUSINESS, USED_CAR, HOME, GOLD
  loanAmount        Float
  interestRate      Float
  tenure            Int      // months
  monthlyEmi        Float?

  // Personal Details
  fullName          String
  email             String
  phone             String
  dateOfBirth       String?
  gender            String?
  address           String?
  city              String?
  state             String?
  pincode           String?

  // Employment Details
  employmentType    String?  // SALARIED, SELF_EMPLOYED, BUSINESS
  employerName      String?
  monthlyIncome     Float?
  workExperience    String?

  // KYC Document URLs (Vercel Blob integration)
  aadhaarUrl         String?
  panUrl             String?
  passbookUrl        String?

  // Document Info (stored as text references, simulated uploads)
  aadhaarNumber     String?
  panNumber         String?
  itrFiled          Boolean  @default(false)
  documentsUploaded String?  // JSON string of uploaded doc names

  // Additional Personal Details
  fatherName          String?
  alternatePhone      String?
  permanentAddress    String?

  // Additional Loan Details
  loanPurpose         String?

  // Existing Loan & Financial
  existingLoan        String?
  existingLoanDetails String?
  existingEmi         String?
  approxCibilScore    String?

  // Document Checklist
  bankStatement       Boolean  @default(false)
  salarySlip          Boolean  @default(false)
  passportPhoto       Boolean  @default(false)

  // Declaration
  declarationAccepted Boolean  @default(false)

  // Application Status
  status            String   @default("PENDING") // PENDING, UNDER_REVIEW, APPROVED, REJECTED
  rejectionReason   String?
  processingFeePaid Boolean  @default(false)

  // Notification tracking
  notificationSent  String?  // JSON of sent notifications

  // Payment Gateway
  paymentOrderId     String?  // Payment gateway order ID
  paymentAmount      Float?   // Amount paid
  paymentMethod      String?  // UPI / PAYTM etc
  paymentStatus      String   @default("PENDING") // PENDING, COMPLETED, FAILED, REFUNDED
  paymentCompletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}
